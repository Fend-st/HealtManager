<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="fend.crono.Cronometro">
  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="#71C3EB"
      android:padding="16dp">

    <!-- Título CRONOMETRO  -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cronómetro"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="16dp" />

    <!-- Contenedor redondeado  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/rounded_container"
        android:padding="24dp"
        android:gravity="center_horizontal">

      <!-- Sección del cronómetro: barra circular y el  tiempo -->
      <FrameLayout
          android:layout_width="220dp"
          android:layout_height="220dp"
          android:layout_gravity="center_horizontal"
          android:layout_marginTop="16dp"
          android:layout_marginBottom="24dp">

        <!-- Barra de progreso circular todo/ nota para nandus: modifica "progress" para hacer avanzar la barra  -->
        <ProgressBar
            android:id="@+id/circularProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="false"
            android:max="120"
            android:progress="0"
            android:progressDrawable="@drawable/circular_progress"
            android:rotation="-90" />

        <!-- tiempo dentro de la barra circular  -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">
          <!-- todo/ nota para nandus: modifica "text" para cambiar los numeros -->
          <TextView
              android:id="@+id/tvTimer"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="00:00:00"
              android:textSize="32sp"
              android:textStyle="bold"
              android:textColor="#1D1D1D" />

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="horas : min : seg"
              android:textSize="12sp"
              android:textColor="#888888"
              android:layout_marginTop="4dp" />

        </LinearLayout>
      </FrameLayout>

      <!-- Divisor para quedar mas ordenado -->
      <View
          android:layout_width="match_parent"
          android:layout_height="1dp"
          android:background="#E0E0E0"
          android:layout_marginBottom="20dp" />

      <!-- botones de actividad -->
      <!-- todo/ nota para nandus: los numeros son place holders para lo que serian los iconitos  -->
      <LinearLayout
          android:id="@+id/llActivityButtons"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:orientation="horizontal"
          android:gravity="center"
          android:weightSum="5">

        <Button
            android:id="@+id/btnActivity1"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="1"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#71C3EB"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnActivity2"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="2"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#71C3EB"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnActivity3"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="3"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#71C3EB"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnActivity4"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="4"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#71C3EB"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnActivity5"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:text="5"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#71C3EB"
            android:stateListAnimator="@null" />

      </LinearLayout>

      <!-- texto que enseña que actividad se esta registrando -->
      <!-- recuerda hacerlo invisible cuando el temporizador este parado (simplemente meterle ningun texto)-->
      <TextView
          android:id="@+id/tvCurrentActivity"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:text="placeholder ACTIVIDAD ACTUAL"
          android:textSize="13sp"
          android:textColor="#444444"
          android:gravity="center"
          android:layout_marginTop="16dp" />

      <Button
          android:id="@+id/btnActivity6"
          android:layout_width="match_parent"
          android:layout_height="64dp"
          android:layout_margin="4dp"
          android:layout_weight="1"
          android:backgroundTint="#71C3EB"
          android:stateListAnimator="@null"
          android:text="PLAY"
          android:textColor="#FFFFFF"
          android:textSize="10sp" />

      <Button
          android:id="@+id/btnActivity7"
          android:layout_width="match_parent"
          android:layout_height="64dp"
          android:layout_margin="4dp"
          android:layout_weight="1"
          android:backgroundTint="#71C3EB"
          android:stateListAnimator="@null"
          android:text="STOP"
          android:textColor="#FFFFFF"
          android:textSize="10sp" />

    </LinearLayout>

  </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>