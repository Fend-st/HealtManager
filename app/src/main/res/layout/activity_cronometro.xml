<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="FernandoDiaz.crono.Cronometro">

  <!-- CONTENEDOR PRINCIPAL -->
  <LinearLayout
      android:id="@+id/mainContent"
      android:layout_width="match_parent"
      android:layout_height="match_parent"
      android:orientation="vertical"
      android:background="#71C3EB"
      android:padding="16dp">

    <!-- Título CRONOMETRO -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cronómetro"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="16dp" />

    <!-- Contenedor redondeado -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/rounded_container"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

      <!-- Sección del cronómetro -->
      <FrameLayout
          android:layout_width="220dp"
          android:layout_height="220dp"
          android:layout_gravity="center_horizontal"
          android:layout_marginTop="16dp"
          android:layout_marginBottom="12dp">

        <ProgressBar
            android:id="@+id/circularProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:indeterminate="true"
            android:indeterminateDrawable="@drawable/circular_progress"
            android:max="120"
            android:progress="0"
            android:rotation="-90"
            android:rotationX="49" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

          <TextView
              android:id="@+id/tvTimer"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:text="00:00:00"
              android:textColor="#1D1D1D"
              android:textSize="32sp"
              android:textStyle="bold" />

          <TextView
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginTop="4dp"
              android:text="horas : min : seg"
              android:textColor="#888888"
              android:textSize="12sp" />

        </LinearLayout>
      </FrameLayout>

      <View
          android:layout_width="match_parent"
          android:layout_height="1dp"
          android:layout_marginBottom="20dp"
          android:background="#E0E0E0" />

      <!-- botones de actividad -->
      <LinearLayout
          android:id="@+id/llActivityButtons"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:gravity="center"
          android:orientation="horizontal"
          android:weightSum="5">

        <ImageButton
            android:id="@+id/btnActivity1"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Caminar"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/icon_walk" />

        <ImageButton
            android:id="@+id/btnActivity2"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Correr"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/icon_run" />

        <ImageButton
            android:id="@+id/btnActivity3"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Gimnasio"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/icon_gym" />

        <ImageButton
            android:id="@+id/btnActivity4"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Ciclismo"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/icon_bike" />

        <ImageButton
            android:id="@+id/btnActivity5"
            android:layout_width="0dp"
            android:layout_height="64dp"
            android:layout_margin="4dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="Yoga"
            android:padding="4dp"
            android:scaleType="fitCenter"
            android:src="@drawable/icon_yoga" />

      </LinearLayout>

      <TextView
          android:id="@+id/tvCurrentActivity"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginTop="16dp"
          android:gravity="center"
          android:text="placeholder ACTIVIDAD ACTUAL"
          android:textColor="#444444"
          android:textSize="13sp" />

      <Button
          android:id="@+id/btnActivity6"
          android:layout_width="match_parent"
          android:layout_height="64dp"
          android:layout_margin="4dp"
          android:layout_weight="1"
          android:backgroundTint="#71C3EB"
          android:stateListAnimator="@null"
          android:text="PLAY"
          android:textColor="#FFFFFF"
          android:textSize="20sp" />

      <Button
          android:id="@+id/btnActivity7"
          android:layout_width="match_parent"
          android:layout_height="64dp"
          android:layout_margin="4dp"
          android:layout_weight="1"
          android:backgroundTint="#71C3EB"
          android:stateListAnimator="@null"
          android:text="STOP"
          android:textColor="#FFFFFF"
          android:textSize="20sp" />

    </LinearLayout>

    <!-- MENÚ NAVEGACIÓN -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/nav_redondeada"
        app:itemIconTint="@color/nav_colors"
        app:itemTextColor="@color/nav_colors"
        app:menu="@menu/barra_navegacion" />


  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>